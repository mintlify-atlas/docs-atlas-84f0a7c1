  "keyFeatures": [
    "Product catalog with filtering, search, and sorting",
    "Shopping cart with persistent storage",
    "Multi-step checkout process",
    "Auth0 authentication integration",
    "Order history tracking",
    "Responsive design with Bootstrap"
  ],
  "publicApiSurface": [
    "useCartStore (addToCart, removeFromCart, increaseQty, decreaseQty, clearCart)",
    "useUserStore (setShipping, setPayment, addOrder, hydrateFromAuth0)",
    "useProducts (fetch all products)",
    "useProduct (fetch product by ID)",
    "useCategories (fetch all categories)",
    "productService (getAll, getById, getByCategory)",
    "categoryService (getAll)"
  ]
